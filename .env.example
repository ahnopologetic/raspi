# Raspberry Pi Home Hub — configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# Tailscale IP of your Pi (find with: tailscale status)
RASPI_TAILSCALE_IP=100.105.94.23

# SSH username on the Pi
RASPI_USER=pi

# Pi hostname (for mDNS: hostname.local)
RASPI_HOSTNAME=raspberrypi

# Pi Wi-Fi MAC address (find with: arp -a while Pi is connected)
RASPI_MAC=b8:27:eb:00:00:00

# Subnet to scan when hunting for the Pi locally (CIDR notation)
RASPI_BUILDING_SUBNET=192.168.1.0/24
